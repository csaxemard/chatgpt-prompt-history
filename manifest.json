{
    "manifest_version": 3,
    "name": "ChatGPT Prompt History",
    "version": "1.0",
    "description": "Affiche un panneau avec l'historique des prompts sur chatgpt.com",
    "permissions": [ "activeTab", "scripting", "storage" ],
    "host_permissions": [ "https://chatgpt.com/*" ],
    "action": {
        "default_popup": "popup/popup.html"
    },
    "content_scripts": [
        {
            "matches": [ "https://chatgpt.com/*" ],
            "js": [ "content.js" ],
            "css": [ "main.css" ]
        }
    ]
}